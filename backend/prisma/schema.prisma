generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  fullName     String   @map("full_name")
  departmentId String   @map("department_id")
  accessRoleId String   @map("access_role_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  department        Department         @relation(fields: [departmentId], references: [id])
  accessRole        AccessRole         @relation(fields: [accessRoleId], references: [id])
  authAccount       AuthAccount?
  groupMemberships  GroupMembership[]
  activityRecords   ActivityRecord[]
  qaWeeklyReports   QaWeeklyReport[]
  licenseOperations LicenseOperation[]
  supportRequests   SupportRequest[]

  @@index([departmentId])
  @@index([accessRoleId])
  @@map("users")
}

model AuthAccount {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @unique @map("user_id") @db.Uuid
  email           String    @unique
  passwordHash    String    @map("password_hash")
  status          String
  emailVerifiedAt DateTime? @map("email_verified_at")
  lastLoginAt     DateTime? @map("last_login_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions AuthSession[]
  createdInvites RegistrationInvite[] @relation("RegistrationInviteCreator")

  @@map("auth_accounts")
}

model RegistrationInvite {
  id                   String     @id @default(uuid()) @db.Uuid
  tokenHash            String     @unique @map("token_hash")
  email                String?
  departmentId         String     @map("department_id") @db.Uuid
  accessRoleId         String     @map("access_role_id") @db.Uuid
  createdByAccountId   String     @map("created_by_account_id") @db.Uuid
  expiresAt            DateTime   @map("expires_at")
  usedAt               DateTime?  @map("used_at")
  createdAt            DateTime   @default(now()) @map("created_at")
  updatedAt            DateTime   @updatedAt @map("updated_at")

  department         Department   @relation(fields: [departmentId], references: [id])
  accessRole         AccessRole   @relation(fields: [accessRoleId], references: [id])
  createdByAccount   AuthAccount  @relation("RegistrationInviteCreator", fields: [createdByAccountId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([createdByAccountId, createdAt])
  @@index([departmentId])
  @@index([accessRoleId])
  @@map("registration_invites")
}

model AuthSession {
  id            String    @id @default(uuid())
  authAccountId String    @map("auth_account_id")
  tokenHash     String    @unique @map("token_hash")
  expiresAt     DateTime  @map("expires_at")
  revokedAt     DateTime? @map("revoked_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  authAccount AuthAccount @relation(fields: [authAccountId], references: [id], onDelete: Cascade)

  @@index([authAccountId, expiresAt])
  @@index([expiresAt])
  @@map("auth_sessions")
}

model AccessRole {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique
  name        String
  description String?
  isSystem    Boolean  @default(true) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users           User[]
  rolePermissions AccessRolePermission[]
  registrationInvites RegistrationInvite[]

  @@map("access_roles")
}

model AccessPermission {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  category    String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  roleAssignments  AccessRolePermission[]
  groupAssignments GroupPermissionAssignment[]

  @@index([category, code])
  @@map("access_permissions")
}

model AccessRolePermission {
  roleId       String   @map("role_id")
  permissionId String   @map("permission_id")
  createdAt    DateTime @default(now()) @map("created_at")

  role       AccessRole       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission AccessPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("access_role_permissions")
}

model Department {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique
  name      String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users           User[]
  groups          Group[]
  registrationInvites RegistrationInvite[]
  activityRecords ActivityRecord[]
  qaWeeklyReports QaWeeklyReport[]

  @@map("departments")
}

model Group {
  id           String   @id @default(uuid())
  code         String   @unique
  name         String
  description  String?
  type         String
  isActive     Boolean  @default(true) @map("is_active")
  departmentId String?  @map("department_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  department            Department?                @relation(fields: [departmentId], references: [id])
  memberships           GroupMembership[]
  permissionAssignments GroupPermissionAssignment[]

  @@index([type, isActive])
  @@index([departmentId])
  @@map("groups")
}

model GroupMembership {
  id        String   @id @default(uuid())
  groupId    String   @map("group_id")
  userId     String   @map("user_id")
  createdAt  DateTime @default(now()) @map("created_at")

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId])
  @@map("group_memberships")
}

model GroupPermissionAssignment {
  id           String   @id @default(uuid())
  groupId      String   @map("group_id")
  permissionId String   @map("permission_id")
  createdAt    DateTime @default(now()) @map("created_at")

  group      Group            @relation(fields: [groupId], references: [id], onDelete: Cascade)
  permission AccessPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([groupId, permissionId])
  @@index([permissionId])
  @@map("group_permission_assignments")
}

model ActivityType {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  activityRecords ActivityRecord[]

  @@map("activity_types")
}

model ActivityResult {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  activityRecords ActivityRecord[]

  @@map("activity_results")
}

model ActivityRecord {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  departmentId     String   @map("department_id")
  activityTypeId   String   @map("activity_type_id")
  activityResultId String   @map("activity_result_id")
  workDate         DateTime @db.Date @map("work_date")
  durationMinutes  Int      @map("duration_minutes")
  title            String
  description      String?
  comment          String?
  externalId       String?  @map("external_id")
  externalUrl      String?  @map("external_url")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user           User           @relation(fields: [userId], references: [id])
  department     Department     @relation(fields: [departmentId], references: [id])
  activityType   ActivityType   @relation(fields: [activityTypeId], references: [id])
  activityResult ActivityResult @relation(fields: [activityResultId], references: [id])

  @@index([userId, workDate])
  @@index([departmentId, workDate])
  @@index([activityTypeId, workDate])
  @@map("activity_records")
}

model LicenseType {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  licenseOperations LicenseOperation[]

  @@map("license_types")
}

model LicenseOperation {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  licenseTypeId   String    @map("license_type_id")
  organization    String?
  quantity        Int       @default(1)
  contactFullName String?   @map("contact_full_name")
  contactEmail    String?   @map("contact_email")
  issuedAt        DateTime? @map("issued_at")
  expiresAt       DateTime? @map("expires_at")
  durationDays    Int?      @map("duration_days")
  operationType   String    @map("operation_type")
  comment         String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user        User        @relation(fields: [userId], references: [id])
  licenseType LicenseType @relation(fields: [licenseTypeId], references: [id])

  @@index([userId])
  @@map("license_operations")
}

model LicenseRegistryImportBatch {
  id                String                 @id @default(uuid())
  sourceDocumentUrl String                 @map("source_document_url")
  sourceSheetName   String                 @map("source_sheet_name")
  totalSourceRows   Int                    @map("total_source_rows")
  importedRows      Int                    @map("imported_rows")
  skippedRows       Int                    @map("skipped_rows")
  isActive          Boolean                @default(true) @map("is_active")
  importedAt        DateTime               @default(now()) @map("imported_at")
  createdAt         DateTime               @default(now()) @map("created_at")

  entries LicenseRegistryEntry[]

  @@index([isActive, importedAt])
  @@map("license_registry_import_batches")
}

model LicenseRegistryEntry {
  id               String   @id @default(uuid())
  importBatchId    String   @map("import_batch_id")
  sourceRowNumber  Int      @map("source_row_number")
  issueDate        DateTime @db.Date @map("issue_date")
  quantity         Int
  licenseType      String   @map("license_type")
  organizationName String?  @map("organization_name")
  recipientEmail   String?  @map("recipient_email")
  issuedTo         String   @map("issued_to")
  createdAt        DateTime @default(now()) @map("created_at")

  importBatch LicenseRegistryImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade)

  @@index([importBatchId, issueDate])
  @@index([issueDate, licenseType])
  @@map("license_registry_entries")
}

model SupportRequestType {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  supportRequests SupportRequest[]

  @@map("support_request_types")
}

model SupportRequest {
  id                   String    @id @default(uuid())
  userId               String    @map("user_id")
  supportRequestTypeId String    @map("support_request_type_id")
  title                String
  description          String?
  channel              String?
  requesterName        String?   @map("requester_name")
  requesterEmail       String?   @map("requester_email")
  organization         String?
  status               String
  resolvedAt           DateTime? @map("resolved_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  user               User               @relation(fields: [userId], references: [id])
  supportRequestType SupportRequestType @relation(fields: [supportRequestTypeId], references: [id])

  @@index([userId])
  @@map("support_requests")
}

model QaWeeklyReport {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @db.Uuid @map("user_id")
  departmentId String    @db.Uuid @map("department_id")
  weekStart    DateTime  @db.Date @map("week_start")
  weekEnd      DateTime  @db.Date @map("week_end")
  status       String
  submittedAt  DateTime? @map("submitted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user           User                @relation(fields: [userId], references: [id])
  department     Department          @relation(fields: [departmentId], references: [id])
  bugItems       QaWeeklyBugItem[]
  otherTaskItems QaWeeklyOtherTaskItem[]

  @@unique([userId, weekStart])
  @@index([departmentId, weekStart])
  @@index([status, weekStart])
  @@map("qa_weekly_reports")
}

model QaWeeklyBugItem {
  id           String   @id @default(uuid()) @db.Uuid
  reportId     String   @db.Uuid @map("report_id")
  bucketCode  String   @map("bucket_code")
  projectName String   @map("project_name")
  title       String
  externalUrl String?  @map("external_url")
  severityCode String?  @map("severity_code")
  resultCode  String?  @map("result_code")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  report QaWeeklyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId, bucketCode, sortOrder])
  @@map("qa_weekly_bug_items")
}

model QaWeeklyOtherTaskItem {
  id              String   @id @default(uuid()) @db.Uuid
  reportId        String   @db.Uuid @map("report_id")
  taskName        String   @map("task_name")
  description     String?  @map("description")
  durationMinutes Int      @map("duration_minutes")
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  report QaWeeklyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId, sortOrder])
  @@map("qa_weekly_other_task_items")
}
