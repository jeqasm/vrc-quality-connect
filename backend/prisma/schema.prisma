generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  fullName     String   @map("full_name")
  role         String
  departmentId String   @map("department_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  department        Department         @relation(fields: [departmentId], references: [id])
  activityRecords   ActivityRecord[]
  licenseOperations LicenseOperation[]
  supportRequests   SupportRequest[]

  @@index([departmentId])
  @@map("users")
}

model Department {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users           User[]
  activityRecords ActivityRecord[]

  @@map("departments")
}

model ActivityType {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  activityRecords ActivityRecord[]

  @@map("activity_types")
}

model ActivityResult {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  activityRecords ActivityRecord[]

  @@map("activity_results")
}

model ActivityRecord {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  departmentId     String   @map("department_id")
  activityTypeId   String   @map("activity_type_id")
  activityResultId String   @map("activity_result_id")
  workDate         DateTime @db.Date @map("work_date")
  durationMinutes  Int      @map("duration_minutes")
  title            String
  description      String?
  comment          String?
  externalId       String?  @map("external_id")
  externalUrl      String?  @map("external_url")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user           User           @relation(fields: [userId], references: [id])
  department     Department     @relation(fields: [departmentId], references: [id])
  activityType   ActivityType   @relation(fields: [activityTypeId], references: [id])
  activityResult ActivityResult @relation(fields: [activityResultId], references: [id])

  @@index([userId, workDate])
  @@index([departmentId, workDate])
  @@index([activityTypeId, workDate])
  @@map("activity_records")
}

model LicenseType {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  licenseOperations LicenseOperation[]

  @@map("license_types")
}

model LicenseOperation {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  licenseTypeId   String    @map("license_type_id")
  organization    String?
  quantity        Int       @default(1)
  contactFullName String?   @map("contact_full_name")
  contactEmail    String?   @map("contact_email")
  issuedAt        DateTime? @map("issued_at")
  expiresAt       DateTime? @map("expires_at")
  durationDays    Int?      @map("duration_days")
  operationType   String    @map("operation_type")
  comment         String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user        User        @relation(fields: [userId], references: [id])
  licenseType LicenseType @relation(fields: [licenseTypeId], references: [id])

  @@index([userId])
  @@map("license_operations")
}

model SupportRequestType {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  supportRequests SupportRequest[]

  @@map("support_request_types")
}

model SupportRequest {
  id                   String    @id @default(uuid())
  userId               String    @map("user_id")
  supportRequestTypeId String    @map("support_request_type_id")
  title                String
  description          String?
  channel              String?
  requesterName        String?   @map("requester_name")
  requesterEmail       String?   @map("requester_email")
  organization         String?
  status               String
  resolvedAt           DateTime? @map("resolved_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  user               User               @relation(fields: [userId], references: [id])
  supportRequestType SupportRequestType @relation(fields: [supportRequestTypeId], references: [id])

  @@index([userId])
  @@map("support_requests")
}
